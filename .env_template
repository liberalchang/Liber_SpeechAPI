# Liber Speech 环境配置模板
# 复制此文件为 .env 并根据需要修改配置

# === 基础配置 ===
# 推理设备: auto (自动检测), cpu, cuda
LIBER_DEVICE=auto

# === 模型配置 ===
# ASR 模型 (Whisper)
LIBER_ASR_MODEL=openai/whisper-large-v3
# 常用选项:
# - openai/whisper-large-v3 (推荐，高精度)
# - openai/whisper-medium (平衡)
# - openai/whisper-small (快速)
# - openai/whisper-base (更快)
# - openai/whisper-tiny (最快)

# TTS 模型 (Chatterbox)
LIBER_TTS_MODEL=multilingual
# 选项:
# - multilingual (多语，推荐)
# - turbo (速度优先)
# - standard (质量优先)

# === API 服务配置 ===
# 鉴权模式: none (无鉴权), api_key (API Key 鉴权)
LIBER_API_AUTH_MODE=api_key

# API Keys (逗号分隔多个 Key)
LIBER_API_KEYS=your_api_key_here

# 监听地址
LIBER_API_HOST=0.0.0.0

# 监听端口 (默认: 5555)
LIBER_API_PORT=5555

# === 异步任务结果管理 ===
# 结果文件目录
LIBER_RESULTS_DIR=results

# 结果保留时长 (小时)
LIBER_RESULTS_TTL_HOURS=24

# === 缓存配置 ===
# HuggingFace 模型缓存目录 (留空使用默认)
# Windows: C:\Users\用户名\.cache\huggingface
# Linux/macOS: ~/.cache/huggingface
# LIBER_HF_CACHE_DIR=/path/to/hf_cache

# HuggingFace 国内镜像/代理加速（可选）
# 说明：download_models.py 会读取 .env，因此这里配置后下载会自动生效
# 常见镜像：
# HF_ENDPOINT=https://hf-mirror.com
# 如果你在公司/校园网需要代理，可设置：
# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890

# === CLI 默认参数 ===
# CLI 命令默认设备
LIBER_CLI_DEVICE=auto

# === 开发配置 ===
# 日志级别: DEBUG, INFO, WARNING, ERROR
# LIBER_LOG_LEVEL=INFO

# 最大并发任务数
# LIBER_MAX_CONCURRENT_TASKS=4

# 音频文件最大大小 (MB)
# LIBER_MAX_AUDIO_SIZE=100

# === 示例配置 ===

# 高性能 GPU 配置
# LIBER_DEVICE=cuda:0
# LIBER_ASR_MODEL=openai/whisper-large-v3
# LIBER_TTS_MODEL=turbo
# LIBER_API_PORT=5555
# LIBER_MAX_CONCURRENT_TASKS=8

# 开发调试配置
# LIBER_DEVICE=cpu
# LIBER_ASR_MODEL=openai/whisper-base
# LIBER_TTS_MODEL=standard
# LIBER_API_AUTH_MODE=none
# LIBER_LOG_LEVEL=DEBUG

# 生产服务配置
# LIBER_DEVICE=cuda:0
# LIBER_ASR_MODEL=openai/whisper-large-v3
# LIBER_TTS_MODEL=multilingual
# LIBER_API_AUTH_MODE=api_key
# LIBER_API_KEYS=key1,key2,key3
# LIBER_API_PORT=5555
# LIBER_RESULTS_TTL_HOURS=72
# LIBER_MAX_CONCURRENT_TASKS=4
